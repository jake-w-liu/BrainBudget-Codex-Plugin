#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any, Sequence


def load_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    return json.loads(path.read_text(encoding="utf-8"))


def write_json_atomic(path: Path, payload: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=path.parent, delete=False) as handle:
        json.dump(payload, handle, indent=2, sort_keys=True)
        handle.write("\n")
        temp_name = handle.name
    Path(temp_name).replace(path)


def parse_args(argv: Sequence[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--install", action="store_true", help="Run `codex plugin add` after wiring the marketplace.")
    parser.add_argument(
        "--install-profiles",
        action="store_true",
        help="Also install the bundled arc-p*.config.toml profiles into CODEX_HOME or ~/.codex.",
    )
    parser.add_argument("--force", action="store_true", help="Replace an existing marketplace entry for this plugin.")
    parser.add_argument("--home", default=os.environ.get("HOME"), help="Home directory to target. Defaults to $HOME.")
    parser.add_argument("--marketplace-name", default=None, help="Optional name for a new marketplace file.")
    return parser.parse_args(argv)


def repo_root() -> Path:
    return Path(__file__).resolve().parent.parent


def read_plugin_manifest(root: Path) -> dict[str, Any]:
    manifest_path = root / ".codex-plugin" / "plugin.json"
    payload = load_json(manifest_path, {})
    if not isinstance(payload, dict):
        raise ValueError(f"{manifest_path} must contain a JSON object")
    return payload


def ensure_plugin_link(*, root: Path, home: Path, plugin_name: str) -> Path:
    target = home / "plugins" / plugin_name
    target.parent.mkdir(parents=True, exist_ok=True)
    if target.is_symlink():
        if target.resolve() == root.resolve():
            return target
        raise ValueError(f"{target} already points to {target.resolve()}, not {root}")
    if target.exists():
        if target.resolve() == root.resolve():
            return target
        raise ValueError(f"{target} already exists and is not this repository")
    target.symlink_to(root, target_is_directory=True)
    return target


def marketplace_path(home: Path) -> Path:
    return home / ".agents" / "plugins" / "marketplace.json"


def default_marketplace(name: str) -> dict[str, Any]:
    return {
        "name": name,
        "interface": {
            "displayName": name.capitalize(),
        },
        "plugins": [],
    }


def build_plugin_entry(plugin_name: str, category: str) -> dict[str, Any]:
    return {
        "name": plugin_name,
        "source": {
            "source": "local",
            "path": f"./plugins/{plugin_name}",
        },
        "policy": {
            "installation": "AVAILABLE",
            "authentication": "ON_INSTALL",
        },
        "category": category,
    }


def upsert_marketplace_entry(
    *,
    path: Path,
    plugin_name: str,
    category: str,
    requested_name: str | None,
    force: bool,
) -> str:
    payload = load_json(path, None)
    if payload is None:
        payload = default_marketplace(requested_name or "personal")
    if not isinstance(payload, dict):
        raise ValueError(f"{path} must contain a JSON object")

    marketplace_name = payload.get("name")
    if not isinstance(marketplace_name, str) or not marketplace_name.strip():
        marketplace_name = requested_name or "personal"
        payload["name"] = marketplace_name
    if requested_name and marketplace_name != requested_name:
        raise ValueError(f"{path} already uses marketplace name {marketplace_name!r}, not {requested_name!r}")

    interface = payload.get("interface")
    if not isinstance(interface, dict):
        interface = {"displayName": str(marketplace_name).capitalize()}
        payload["interface"] = interface
    elif "displayName" not in interface:
        interface["displayName"] = str(marketplace_name).capitalize()

    plugins = payload.get("plugins")
    if not isinstance(plugins, list):
        raise ValueError(f"{path} field 'plugins' must be an array")

    new_entry = build_plugin_entry(plugin_name, category)
    replaced = False
    for index, entry in enumerate(plugins):
        if isinstance(entry, dict) and entry.get("name") == plugin_name:
            if not force and entry != new_entry:
                raise ValueError(f"Marketplace entry {plugin_name!r} already exists in {path}; rerun with --force")
            plugins[index] = new_entry
            replaced = True
            break
    if not replaced:
        plugins.append(new_entry)

    payload["plugins"] = plugins
    write_json_atomic(path, payload)
    return str(marketplace_name)


def run_checked(cmd: Sequence[str], *, env: dict[str, str]) -> None:
    completed = subprocess.run(list(cmd), env=env, check=False)
    if completed.returncode != 0:
        raise SystemExit(completed.returncode)


def main(argv: Sequence[str] | None = None) -> int:
    args = parse_args(argv)
    if not args.home:
        raise ValueError("--home or $HOME is required")

    root = repo_root()
    home = Path(args.home).expanduser().resolve()
    manifest = read_plugin_manifest(root)
    plugin_name = str(manifest.get("name") or "").strip()
    if not plugin_name:
        raise ValueError("plugin manifest is missing name")

    category = str(((manifest.get("interface") or {}) if isinstance(manifest.get("interface"), dict) else {}).get("category") or "Productivity")

    link_path = ensure_plugin_link(root=root, home=home, plugin_name=plugin_name)
    mkt_path = marketplace_path(home)
    mkt_name = upsert_marketplace_entry(
        path=mkt_path,
        plugin_name=plugin_name,
        category=category,
        requested_name=args.marketplace_name,
        force=args.force,
    )

    env = dict(os.environ)
    env["HOME"] = str(home)
    env.setdefault("CODEX_HOME", str(home / ".codex"))

    if args.install_profiles:
        run_checked([str(root / "scripts" / "install-arc-profiles")], env=env)

    if args.install:
        run_checked(["codex", "plugin", "add", f"{plugin_name}@{mkt_name}"], env=env)

    summary = {
        "plugin_name": plugin_name,
        "plugin_link": str(link_path),
        "marketplace_path": str(mkt_path),
        "marketplace_name": mkt_name,
        "profiles_installed": args.install_profiles,
        "plugin_installed": args.install,
        "next_command": f"codex plugin add {plugin_name}@{mkt_name}" if not args.install else None,
    }
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
