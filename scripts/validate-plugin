#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VALIDATOR="/Users/jake/.codex/skills/.system/plugin-creator/scripts/validate_plugin.py"

if python3 - <<'PY' >/dev/null 2>&1
import yaml
PY
then
  exec python3 "$VALIDATOR" "$PLUGIN_ROOT"
fi

VENV_DIR="${TMPDIR:-/private/tmp}/stupidmeter-validate-venv"
python3 -m venv "$VENV_DIR"
"$VENV_DIR/bin/pip" install -q PyYAML
exec "$VENV_DIR/bin/python" "$VALIDATOR" "$PLUGIN_ROOT"
